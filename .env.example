# Required — get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional — public website URL (defaults to https://nibbo.fun)
WEBSITE_URL=https://nibbo.fun

# Optional — Solana mint / contract address for /price
# Leave empty until launch; bot will reply with a cute "coming soon" message
TOKEN_MINT=

# Optional — DexScreener / Jupiter price API base (advanced)
# PRICE_API_URL=https://api.dexscreener.com/latest/dex/tokens

# Optional — Node environment
NODE_ENV=production
